{
  "name": "murf-tts",
  "version": "0.2.5",
  "description": "OpenClaw TTS plugin for Murf AI — low-latency neural text-to-speech via the Falcon model. 150+ AI voices, 35 languages, 12 regional endpoints. Voice-agent and Discord/Telegram/Matrix voice-note ready.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.mjs"
    ],
    "providers": [
      "murf"
    ],
    "compat": {
      "pluginApi": ">=2026.4.1",
      "minGatewayVersion": "2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsdown": "latest",
    "typescript": "^5",
    "vitest": "^2"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "clawhub",
    "tts",
    "text-to-speech",
    "speech-synthesis",
    "speech",
    "voice",
    "audio",
    "ai-voice",
    "neural-tts",
    "murf",
    "murf-ai",
    "falcon",
    "multilingual",
    "voice-agent",
    "voice-assistant",
    "chatbot",
    "discord-bot",
    "telegram-bot",
    "matrix-bot",
    "voice-note",
    "provider-plugin",
    "typescript"
  ],
  "author": "Sanchita Sunil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanchitasunil/murf-openclaw-plugin.git"
  }
}
